{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hakuneko.dev/schemas/source-v1.json",
  "title": "HakuNeko Source Definition v1",
  "description": "Declarative definition of a manga source. Add = write one of these; remove = delete it.",
  "type": "object",
  "required": ["id", "label", "url", "template"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "description": "Unique, stable, URL-safe identifier."
    },
    "label": { "type": "string", "minLength": 1 },
    "url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://",
      "description": "Base site URL."
    },
    "template": {
      "type": "string",
      "description": "Name of a registered scraping template (e.g. wordpress-madara)."
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "path": { "type": "string", "description": "Template sub-path (e.g. /list/)." },
    "language": { "type": "string", "description": "ISO code, e.g. en, ja, es." },
    "nsfw": { "type": "boolean", "default": false },
    "icon": { "type": "string", "description": "Icon as a data: URI." },
    "overrides": {
      "type": "object",
      "description": "Template-specific selector/option overrides.",
      "additionalProperties": true
    },
    "disabled": {
      "type": "boolean",
      "description": "Tombstone: masks a bundled catalog source the user removed."
    },
    "origin": { "type": "string", "enum": ["bundled", "user"] }
  }
}
